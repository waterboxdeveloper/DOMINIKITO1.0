# Copia este archivo a backend/.env y rellena tus claves.
# En despliegue, define estas variables en el panel del host (NO subas el .env real).

# --- Gemini (Google AI Studio): https://aistudio.google.com/apikey ---
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Modelos de texto (agentes). Por defecto gemini-2.5-flash si se omiten.
NARRADOR_MODEL=gemini-2.5-flash
DILEMAS_MODEL=gemini-2.5-flash

# --- Imágenes (Nano Banana) ---
IMAGE_MODEL=gemini-2.5-flash-image

# --- ElevenLabs (narración por voz): https://elevenlabs.io/app/settings/api-keys ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE_ID=    # opcional; usa GET /api/voices o el Voice Library para elegir

# --- Servidor (deploy) ---
# HOST=0.0.0.0
# PORT=8080

# --- Persistencia ---
# Cuentos y decisiones se guardan CLIENT-SIDE en Firebase/Firestore (config en web/static/app.js).
# El backend no necesita credenciales de base de datos.
